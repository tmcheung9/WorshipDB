# Google Cloud Production Environment Variables
# Copy this file to .env for local testing or use Secret Manager for production

# Database Configuration
# Use your Supabase connection string or Cloud SQL connection
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Session Configuration
# Generate a strong random secret: openssl rand -base64 32
SESSION_SECRET=your-secure-random-session-secret-here

# Application Configuration
NODE_ENV=production
PORT=8080

# Google Drive Integration (Optional)
# For production, set up standard Google OAuth instead of Replit connectors
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# OpenAI Configuration (Optional - for AI extraction features)
# OPENAI_API_KEY=your-openai-api-key

# Additional Notes:
# - Never commit this file with real values to version control
# - Use Google Secret Manager for production secrets
# - The default admin user (admin/admin123) is created automatically on first startup
# - Change the admin password immediately after first login
